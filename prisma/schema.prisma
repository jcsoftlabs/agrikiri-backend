generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// ENUMS
// ================================

enum Role {
  CUSTOMER
  AYIZAN
  ADMIN
}

enum MlmLevel {
  AYIZAN
  GUACANAGARIC
  MACKANDAL
  BOUKMAN
  SANITE_BELAIRE
  TOUSSAINT_LOUVERTURE
  CATHERINE_FLON
  JEAN_JACQUES_DESSALINES
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PLOPPLOP
  MONCASH
  CASH
  NATCASH
  KASHPAW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum CommissionType {
  DIRECT
  NETWORK
  MONTHLY_BONUS
  LEVEL_BONUS
}

enum CommissionStatus {
  PENDING
  VALIDATED
  PAID
}

// ================================
// MODELS
// ================================

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  phone                String    @unique
  passwordHash         String
  firstName            String
  lastName             String
  avatarUrl            String?
  avatarPublicId       String?
  role                 Role      @default(CUSTOMER)
  mlmLevel             MlmLevel  @default(AYIZAN)
  sponsorId            String?
  sponsor              User?     @relation("SponsorDownline", fields: [sponsorId], references: [id])
  downline             User[]    @relation("SponsorDownline")
  isActive             Boolean   @default(true)
  monthsAtCurrentLevel Int       @default(0)
  personalVolume       Decimal   @default(0) @db.Decimal(10, 2)
  referralCode         String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  ordersAsCustomer     Order[]         @relation("CustomerOrders")
  ordersAsAyizan       Order[]         @relation("AyizanOrders")
  commissionsReceived  Commission[]    @relation("AyizanCommissions")
  commissionSource     Commission[]    @relation("SourceCommissions")
  monthlyPerformances  MonthlyPerformance[]
  notifications        Notification[]
  addresses            CustomerAddress[]

  @@index([sponsorId])
}

model CustomerAddress {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label                String
  countryCode          String
  fullName             String
  phoneCountryCode     String
  phoneNumber          String
  addressLine1         String
  addressLine2         String?
  city                 String
  stateRegion          String
  postalCode           String?
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

model Category {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  description  String?
  imageUrl     String?
  imagePublicId String?
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  description   String
  price         Decimal        @db.Decimal(10, 2)
  weightLbs     Decimal        @db.Decimal(10, 2)
  stockQuantity Int            @default(0)
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  vpPoints      Decimal        @db.Decimal(10, 2)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orderItems    OrderItem[]

  @@index([categoryId])
  @@index([slug])
}

model ProductVariant {
  id            String      @id @default(uuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  label         String
  price         Decimal     @db.Decimal(10, 2)
  weightLbs     Decimal     @db.Decimal(10, 2)
  stockQuantity Int         @default(0)
  vpPoints      Decimal     @db.Decimal(10, 2)
  isDefault     Boolean     @default(false)
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]

  @@index([productId])
  @@index([productId, isActive])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  @@index([productId])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  customerId      String
  customer        User          @relation("CustomerOrders", fields: [customerId], references: [id])
  ayizanId        String?
  ayizan          User?         @relation("AyizanOrders", fields: [ayizanId], references: [id])
  status          OrderStatus   @default(PENDING)
  totalAmount     Decimal       @db.Decimal(10, 2)
  totalVP         Decimal       @db.Decimal(10, 2)
  deliveryAddress Json
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  carrierName     String?
  trackingNumber  String?
  estimatedDeliveryDate DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  items           OrderItem[]
  commissions     Commission[]
  trackingEvents  OrderTrackingEvent[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([ayizanId])
  @@index([status])
}

model OrderTrackingEvent {
  id                String      @id @default(uuid())
  orderId           String
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status            OrderStatus?
  title             String
  description       String?
  isCustomerVisible Boolean     @default(true)
  createdAt         DateTime    @default(now())

  @@index([orderId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  vpPoints  Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productVariantId])
}

model Commission {
  id           String           @id @default(uuid())
  ayizanId     String
  ayizan       User             @relation("AyizanCommissions", fields: [ayizanId], references: [id])
  orderId      String?
  order        Order?           @relation(fields: [orderId], references: [id])
  sourceUserId String?
  sourceUser   User?            @relation("SourceCommissions", fields: [sourceUserId], references: [id])
  type         CommissionType
  amount       Decimal          @db.Decimal(10, 2)
  percentage   Decimal          @db.Decimal(5, 2)
  mlmLevel     String
  status       CommissionStatus @default(PENDING)
  month        Int
  year         Int
  createdAt    DateTime         @default(now())

  @@index([ayizanId])
  @@index([month, year])
  @@index([status])
}

model MonthlyPerformance {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  month               Int
  year                Int
  personalVP          Decimal  @db.Decimal(10, 2)
  networkVP           Decimal  @db.Decimal(10, 2)
  totalCommissions    Decimal  @db.Decimal(10, 2)
  directCommissions   Decimal  @db.Decimal(10, 2)
  networkCommissions  Decimal  @db.Decimal(10, 2)
  bonus               Decimal  @db.Decimal(10, 2) @default(0)
  quotaReached        Boolean  @default(false)
  downlineCount       Int      @default(0)
  createdAt           DateTime @default(now())

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
