generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// ENUMS
// ================================

enum Role {
  CUSTOMER
  AYIZAN
  BUYER
  DELIVERY_AGENT
  CASHIER
  ACCOUNTANT
  ADMIN
  ASSOCIATE
}

enum AssociateType {
  PDG
  VOTING
  OBSERVER
}

enum MlmLevel {
  CUSTOMER
  AYIZAN
  GUACANAGARIC
  MACKANDAL
  BOUKMAN
  SANITE_BELAIRE
  TOUSSAINT_LOUVERTURE
  CATHERINE_FLON
  JEAN_JACQUES_DESSALINES
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  DELIVERY_FAILED
  CANCELLED
}

enum PaymentMethod {
  PLOPPLOP
  MONCASH
  CASH
  NATCASH
  KASHPAW
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum DeliveryMode {
  INTERNAL
  EXTERNAL
}

enum CommissionType {
  DIRECT
  NETWORK
  MONTHLY_BONUS
  LEVEL_BONUS
}

enum CommissionStatus {
  PENDING
  VALIDATED
  PAID
}

enum BuyerAllocationStatus {
  PENDING_CONFIRMATION
  ACTIVE
  PARTIALLY_REPORTED
  REPORTED
}

enum BuyerFundRequestStatus {
  PENDING
  FULFILLED
  DECLINED
}

enum PosDocumentType {
  RECEIPT
  INVOICE
  PROFORMA
}

enum PosSaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PosCustomerType {
  WALK_IN
  INDIVIDUAL
  BUSINESS
}

enum DeliveryNoteSourceType {
  ORDER
  POS_SALE
}

enum DeliveryNoteStatus {
  PREPARED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

// ================================
// MODELS
// ================================

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  phone                String    @unique
  passwordHash         String
  firstName            String
  lastName             String
  avatarUrl            String?
  avatarPublicId       String?
  role                 Role      @default(CUSTOMER)
  associateType        AssociateType?
  mlmLevel             MlmLevel  @default(CUSTOMER)
  sponsorId            String?
  sponsor              User?     @relation("SponsorDownline", fields: [sponsorId], references: [id])
  downline             User[]    @relation("SponsorDownline")
  isActive             Boolean   @default(true)
  monthsAtCurrentLevel Int       @default(0)
  personalVolume       Decimal   @default(0) @db.Decimal(10, 2)
  referralCode         String?   @unique
  passwordResetCode    String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  ordersAsCustomer     Order[]         @relation("CustomerOrders")
  ordersAsAyizan       Order[]         @relation("AyizanOrders")
  commissionsReceived  Commission[]    @relation("AyizanCommissions")
  commissionSource     Commission[]    @relation("SourceCommissions")
  monthlyPerformances  MonthlyPerformance[]
  notifications        Notification[]
  addresses            CustomerAddress[]
  assignedDeliveries   Order[]         @relation("AssignedDeliveryAgent")
  assignedDeliveryNotes DeliveryNote[] @relation("DeliveryNoteAssignedAgent")
  deliveryAgentReports DeliveryAgentReport[] @relation("DeliveryAgentReports")
  buyerAllocations     BuyerAllocation[] @relation("BuyerAllocations")
  allocatedBuyerFunds  BuyerAllocation[] @relation("BuyerAllocatedBy")
  buyerExpenseReports  BuyerExpenseReport[]
  buyerFundRequests    BuyerFundRequest[] @relation("BuyerFundRequestOwner")
  reviewedFundRequests BuyerFundRequest[] @relation("BuyerFundRequestReviewer")
  posSalesCreated      PosSale[]       @relation("PosSaleCreator")
  createdDeliveryNotes DeliveryNote[]  @relation("DeliveryNoteCreatedBy")
  
  // Relations Associés
  createdDossiers      Dossier[]       @relation("DossierAuthor")
  dossierDecisions     DossierDecision[]
  ballots              Ballot[]
  sentMessages         InternalMessage[]
  dossierComments      DossierComment[]


  @@index([sponsorId])
}


model CustomerAddress {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label                String
  countryCode          String
  fullName             String
  phoneCountryCode     String
  phoneNumber          String
  addressLine1         String
  addressLine2         String?
  city                 String
  stateRegion          String
  postalCode           String?
  deliveryInstructions String?
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

model Category {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  description  String?
  imageUrl     String?
  imagePublicId String?
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  description   String
  price         Decimal        @db.Decimal(10, 2)
  weightLbs     Decimal        @db.Decimal(10, 2)
  stockQuantity Int            @default(0)
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  vpPoints      Decimal        @db.Decimal(10, 2)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orderItems    OrderItem[]
  posSaleItems  PosSaleItem[]
  deliveryNoteItems DeliveryNoteItem[]

  @@index([categoryId])
  @@index([slug])
}

model ProductVariant {
  id            String      @id @default(uuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  label         String
  price         Decimal     @db.Decimal(10, 2)
  weightLbs     Decimal     @db.Decimal(10, 2)
  stockQuantity Int         @default(0)
  vpPoints      Decimal     @db.Decimal(10, 2)
  isDefault     Boolean     @default(false)
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]
  pricingTiers  ProductVariantPricingTier[]
  posSaleItems  PosSaleItem[]
  deliveryNoteItems DeliveryNoteItem[]

  @@index([productId])
  @@index([productId, isActive])
}

model ProductVariantPricingTier {
  id               String         @id @default(uuid())
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  minQuantity      Int
  maxQuantity      Int?
  price            Decimal        @db.Decimal(10, 2)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([productVariantId])
  @@index([productVariantId, sortOrder])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  @@index([productId])
}

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  customerId      String
  customer        User          @relation("CustomerOrders", fields: [customerId], references: [id])
  ayizanId        String?
  ayizan          User?         @relation("AyizanOrders", fields: [ayizanId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotalAmount  Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  totalVP         Decimal       @db.Decimal(10, 2)
  deliveryAddress Json
  deliveryMode    DeliveryMode  @default(INTERNAL)
  deliveryAgentId String?
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  deliveryAgent   User?         @relation("AssignedDeliveryAgent", fields: [deliveryAgentId], references: [id])
  carrierName     String?
  deliveryAgentName  String?
  deliveryAgentPhone String?
  deliveryZone       String?
  trackingNumber  String?
  estimatedDeliveryDate DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  deliveryRecipientName String?
  deliveryProofNote String?
  deliveryProofPhotoUrl String?
  deliveryProofPhotoPublicId String?
  deliverySignatureUrl String?
  deliverySignaturePublicId String?
  deliveredLatitude Decimal? @db.Decimal(10, 7)
  deliveredLongitude Decimal? @db.Decimal(10, 7)
  deliveredLocationAccuracy Decimal? @db.Decimal(10, 2)
  deliveryProofCapturedAt DateTime?
  items           OrderItem[]
  deliveryNotes   DeliveryNote[]
  commissions     Commission[]
  trackingEvents  OrderTrackingEvent[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
  @@index([ayizanId])
  @@index([deliveryAgentId])
  @@index([status])
}

model OrderTrackingEvent {
  id                String      @id @default(uuid())
  orderId           String
  order             Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status            OrderStatus?
  title             String
  description       String?
  isCustomerVisible Boolean     @default(true)
  createdAt         DateTime    @default(now())

  @@index([orderId, createdAt])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  vpPoints  Decimal @db.Decimal(10, 2)
  deliveryNoteItems DeliveryNoteItem[]

  @@index([orderId])
  @@index([productVariantId])
}

model PosSale {
  id              String          @id @default(uuid())
  saleNumber      String          @unique
  documentType    PosDocumentType
  status          PosSaleStatus   @default(COMPLETED)
  customerType    PosCustomerType @default(WALK_IN)
  customerName    String
  companyName     String?
  taxId           String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?
  paymentMethod   PaymentMethod?
  subtotalAmount  Decimal         @db.Decimal(10, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal         @db.Decimal(10, 2)
  notes           String?
  createdById     String
  createdBy       User            @relation("PosSaleCreator", fields: [createdById], references: [id])
  items           PosSaleItem[]
  deliveryNotes   DeliveryNote[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([documentType, createdAt])
  @@index([createdById, createdAt])
  @@index([status])
}

model PosSaleItem {
  id               String          @id @default(uuid())
  posSaleId        String
  posSale          PosSale         @relation(fields: [posSaleId], references: [id], onDelete: Cascade)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  description      String
  quantity         Int
  unitPrice        Decimal         @db.Decimal(10, 2)
  lineTotal        Decimal         @db.Decimal(10, 2)
  deliveryNoteItems DeliveryNoteItem[]

  @@index([posSaleId])
  @@index([productId])
  @@index([productVariantId])
}

model DeliveryNote {
  id               String                 @id @default(uuid())
  noteNumber       String                 @unique
  sourceType       DeliveryNoteSourceType
  orderId          String?
  order            Order?                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  posSaleId        String?
  posSale          PosSale?               @relation(fields: [posSaleId], references: [id], onDelete: Cascade)
  deliveryAgentId  String?
  deliveryAgent    User?                  @relation("DeliveryNoteAssignedAgent", fields: [deliveryAgentId], references: [id])
  createdById      String
  createdBy        User                   @relation("DeliveryNoteCreatedBy", fields: [createdById], references: [id])
  status           DeliveryNoteStatus     @default(PREPARED)
  customerName     String
  customerPhone    String?
  customerAddress  String?
  notes            String?
  totalQuantity    Int                    @default(0)
  totalWeightLbs   Decimal                @default(0) @db.Decimal(10, 2)
  deliveredAt      DateTime?
  items            DeliveryNoteItem[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([orderId])
  @@index([posSaleId])
  @@index([deliveryAgentId, status])
  @@index([sourceType, createdAt])
}

model DeliveryNoteItem {
  id               String          @id @default(uuid())
  deliveryNoteId   String
  deliveryNote     DeliveryNote    @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  orderItemId      String?
  orderItem        OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  posSaleItemId    String?
  posSaleItem      PosSaleItem?    @relation(fields: [posSaleItemId], references: [id], onDelete: SetNull)
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  description      String
  orderedQuantity  Int
  deliveredQuantity Int
  remainingQuantity Int
  unitWeightLbs    Decimal         @default(0) @db.Decimal(10, 2)
  lineWeightLbs    Decimal         @default(0) @db.Decimal(10, 2)

  @@index([deliveryNoteId])
  @@index([orderItemId])
  @@index([posSaleItemId])
  @@index([productId])
  @@index([productVariantId])
}

model Commission {
  id           String           @id @default(uuid())
  ayizanId     String
  ayizan       User             @relation("AyizanCommissions", fields: [ayizanId], references: [id])
  orderId      String?
  order        Order?           @relation(fields: [orderId], references: [id])
  sourceUserId String?
  sourceUser   User?            @relation("SourceCommissions", fields: [sourceUserId], references: [id])
  type         CommissionType
  amount       Decimal          @db.Decimal(10, 2)
  percentage   Decimal          @db.Decimal(5, 2)
  mlmLevel     String
  status       CommissionStatus @default(PENDING)
  month        Int
  year         Int
  createdAt    DateTime         @default(now())

  @@index([ayizanId])
  @@index([month, year])
  @@index([status])
}

model MonthlyPerformance {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  month               Int
  year                Int
  personalVP          Decimal  @db.Decimal(10, 2)
  networkVP           Decimal  @db.Decimal(10, 2)
  totalCommissions    Decimal  @db.Decimal(10, 2)
  directCommissions   Decimal  @db.Decimal(10, 2)
  networkCommissions  Decimal  @db.Decimal(10, 2)
  bonus               Decimal  @db.Decimal(10, 2) @default(0)
  quotaReached        Boolean  @default(false)
  downlineCount       Int      @default(0)
  createdAt           DateTime @default(now())

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model DeliveryAgentReport {
  id             String   @id @default(uuid())
  deliveryAgentId String
  deliveryAgent   User     @relation("DeliveryAgentReports", fields: [deliveryAgentId], references: [id])
  title          String
  shiftDate      DateTime
  summary        String
  totalAssigned  Int      @default(0)
  deliveredCount Int      @default(0)
  failedCount    Int      @default(0)
  cashCollected  Decimal  @default(0) @db.Decimal(10, 2)
  fieldExpenses  Decimal  @default(0) @db.Decimal(10, 2)
  incidents      String?
  nextActions    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([deliveryAgentId, createdAt])
  @@index([shiftDate])
}

model BuyerAllocation {
  id                String                @id @default(uuid())
  buyerId           String
  buyer             User                  @relation("BuyerAllocations", fields: [buyerId], references: [id])
  allocatedById     String
  allocatedBy       User                  @relation("BuyerAllocatedBy", fields: [allocatedById], references: [id])
  title             String
  description       String?
  amountAllocated   Decimal               @db.Decimal(10, 2)
  status            BuyerAllocationStatus @default(PENDING_CONFIRMATION)
  receivedConfirmedAt DateTime?
  reports           BuyerExpenseReport[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([buyerId, status])
  @@index([allocatedById])
}

model BuyerExpenseReport {
  id              String            @id @default(uuid())
  allocationId    String
  allocation      BuyerAllocation   @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  buyerId         String
  buyer           User              @relation(fields: [buyerId], references: [id])
  summary         String?
  totalSpent      Decimal           @default(0) @db.Decimal(10, 2)
  totalFees       Decimal           @default(0) @db.Decimal(10, 2)
  totalReported   Decimal           @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal           @default(0) @db.Decimal(10, 2)
  lines           BuyerExpenseLine[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([allocationId, createdAt])
  @@index([buyerId])
}

model BuyerExpenseLine {
  id          String            @id @default(uuid())
  reportId    String
  report      BuyerExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sortOrder   Int               @default(0)
  description String
  quantity    Decimal           @db.Decimal(10, 2)
  unitPrice   Decimal           @db.Decimal(10, 2)
  fees        Decimal           @default(0) @db.Decimal(10, 2)
  lineAmount  Decimal           @db.Decimal(10, 2)

  @@index([reportId, sortOrder])
}

model BuyerFundRequest {
  id              String                 @id @default(uuid())
  buyerId         String
  buyer           User                   @relation("BuyerFundRequestOwner", fields: [buyerId], references: [id])
  title           String
  justification   String
  amountRequested Decimal                @db.Decimal(10, 2)
  status          BuyerFundRequestStatus @default(PENDING)
  reviewNote      String?
  reviewedById    String?
  reviewedBy      User?                  @relation("BuyerFundRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([buyerId, status])
  @@index([status, createdAt])
  @@index([reviewedById])
}

// ================================
// ASSOCIATES MODELS
// ================================

model Dossier {
  id          String   @id @default(uuid())
  title       String
  description String
  disbursementLines Json?
  disbursementTotal Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, ARCHIVED
  authorId    String
  author      User     @relation("DossierAuthor", fields: [authorId], references: [id])
  documents   DossierDocument[]
  votes       Vote[]
  comments    DossierComment[]
  decisions   DossierDecision[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  @@index([authorId])
}

model DossierDecision {
  id        String   @id @default(uuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  action    String   // APPROVE, REJECT, REQUEST_CHANGES
  note      String?
  createdAt DateTime @default(now())

  @@index([dossierId])
  @@index([authorId])
}

model DossierDocument {
  id        String   @id @default(uuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  name      String
  url       String
  createdAt DateTime @default(now())

  @@index([dossierId])
}

model Vote {
  id          String   @id @default(uuid())
  dossierId   String?
  dossier     Dossier? @relation(fields: [dossierId], references: [id])
  title       String
  description String?
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  ballots     Ballot[]
  createdAt   DateTime @default(now())

  @@index([dossierId])
}

model Ballot {
  id        String   @id @default(uuid())
  voteId    String
  vote      Vote     @relation(fields: [voteId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  choice    String   // FOR, AGAINST, ABSTAIN
  createdAt DateTime @default(now())

  @@unique([voteId, userId])
  @@index([voteId])
  @@index([userId])
}

model InternalMessage {
  id        String   @id @default(uuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([senderId])
}

model DossierComment {
  id        String   @id @default(uuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([dossierId])
  @@index([authorId])
}
